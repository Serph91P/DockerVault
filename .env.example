# Docker Backup Manager - Environment Configuration

# ==========================================
# General Settings
# ==========================================

# Port for the web interface
PORT=8080

# Timezone
TZ=Europe/Berlin

# Path where backups are stored on the host
# This gets mounted to /backups in the container
BACKUP_PATH=./backups

# ==========================================
# Docker Settings
# ==========================================

# Docker Group ID - find with: getent group docker | cut -d: -f3
# Required for the container to access the Docker socket
DOCKER_GID=999

# ==========================================
# Komodo Integration (Optional)
# ==========================================

# Enable Komodo integration
KOMODO_ENABLED=false

# Komodo API URL
KOMODO_API_URL=

# Komodo API Key
KOMODO_API_KEY=
