# DockerVault - Environment Configuration
# Copy this file to .env and adjust values as needed
#
# Lines starting with # are comments.
# Uncomment (remove the #) and set a value to override the default.

# ==========================================
# General Settings
# ==========================================

# Port for the web interface (host port mapped to container port 80)
PORT=8080

# Timezone (used for scheduling, logs, and displayed times)
TZ=Europe/Berlin

# Path where backups are stored on the host
# This gets mounted to /backups inside the container
BACKUP_PATH=./backups

# ==========================================
# Security
# ==========================================

# Set session cookies with the Secure flag (requires HTTPS).
# Default: true — leave enabled when running behind a TLS-terminating
# reverse proxy (Traefik, Caddy, nginx, etc.).
# Set to false ONLY for local development over plain HTTP.
#COOKIE_SECURE=true

# Allowed CORS origins (comma-separated).
# Only needed when the frontend is served from a different domain.
# Default: http://localhost
#CORS_ORIGINS=http://localhost

# Encryption key for stored remote-storage credentials.
# If left empty, a key is auto-generated and saved to /app/data/.credential_key.
# Set explicitly if you want to use the same key across container recreations
# without relying on the data volume.
#CREDENTIAL_ENCRYPTION_KEY=

# Comma-separated list of binaries allowed in pre/post backup hooks.
# Default: pg_dump,pg_dumpall,mysqldump,mongodump,redis-cli,mariadb-dump
#ALLOWED_HOOK_COMMANDS=pg_dump,pg_dumpall,mysqldump,mongodump,redis-cli,mariadb-dump

# Maximum execution time (seconds) for pre/post backup hook commands.
# Default: 300
#HOOK_COMMAND_TIMEOUT=300

# Comma-separated directories where SSH keys are allowed to be read from.
# Default: /app/data/ssh_keys,/root/.ssh
#ALLOWED_SSH_KEY_DIRS=/app/data/ssh_keys,/root/.ssh

# Enable FastAPI /docs and /redoc endpoints (for development/debugging).
# Default: false
#ENABLE_DOCS=false

# ==========================================
# Logging
# ==========================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
#LOG_LEVEL=INFO

# Log format: "text" for human-readable, "json" for structured JSON output
# Default: text
#LOG_FORMAT=text

# ==========================================
# Default Retention Policy
# ==========================================
# These defaults apply when creating new backup targets.
# Each target can override these in the UI.

# Keep the last N backups regardless of age. Default: 3
#DEFAULT_KEEP_LAST=3

# Keep one backup per day for the last N days. Default: 7
#DEFAULT_KEEP_DAILY=7

# Keep one backup per week for the last N weeks. Default: 4
#DEFAULT_KEEP_WEEKLY=4

# Keep one backup per month for the last N months. Default: 6
#DEFAULT_KEEP_MONTHLY=6

# Keep one backup per year for the last N years. Default: 2
#DEFAULT_KEEP_YEARLY=2

# ==========================================
# Advanced / Internal
# ==========================================

# Graceful shutdown timeout (seconds) for in-progress backups.
# Default: 30
#SHUTDOWN_TIMEOUT=30

# ==========================================
# Komodo Integration (Optional)
# ==========================================

# Enable Komodo stack management integration.
# Default: false
KOMODO_ENABLED=false

# Komodo API URL (e.g. https://komodo.example.com)
#KOMODO_API_URL=

# Komodo API credentials
#KOMODO_API_KEY=
#KOMODO_API_SECRET=
